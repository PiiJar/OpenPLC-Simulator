    <pous>
      <pou name="IsWetStationType" pouType="function">
        <interface>
          <returnType>
            <BOOL/>
          </returnType>
          <inputVars>
            <variable name="station_type">
              <type>
                <INT/>
              </type>
            </variable>
          </inputVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[IsWetStationType := (station_type = 1) OR (station_type = 11);]]></xhtml:p>
          </ST>
        </body>
      </pou>
      <pou name="FindStationIndexByNumber" pouType="function">
        <interface>
          <returnType>
            <INT/>
          </returnType>
          <inputVars>
            <variable name="station_number">
              <type>
                <INT/>
              </type>
            </variable>
          </inputVars>
          <localVars>
            <variable name="i">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="tmp_st">
              <type>
                <derived name="STATION_T"/>
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[FindStationIndexByNumber := 0;
FOR i := 1 TO g_station_count DO
  tmp_st := g_stations[i];
  IF tmp_st.number = station_number THEN
    FindStationIndexByNumber := i;
    RETURN;
  END_IF;
END_FOR;]]></xhtml:p>
          </ST>
        </body>
      </pou>
      <pou name="GetStationX" pouType="function">
        <interface>
          <returnType>
            <REAL/>
          </returnType>
          <inputVars>
            <variable name="station_number">
              <type>
                <INT/>
              </type>
            </variable>
          </inputVars>
          <localVars>
            <variable name="idx">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="tmp_st">
              <type>
                <derived name="STATION_T"/>
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[idx := FindStationIndexByNumber(station_number);
IF idx > 0 THEN
  tmp_st := g_stations[idx];
  GetStationX := tmp_st.x_mm;
ELSE
  GetStationX := 0.0;
END_IF;]]></xhtml:p>
          </ST>
        </body>
      </pou>
