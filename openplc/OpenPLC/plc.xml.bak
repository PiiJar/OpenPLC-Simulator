            <initialValue>
              <simpleValue value="10"/>
            </initialValue>
          </variable>
          <variable name="MAX_STATIONS">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="21"/>
            </initialValue>
          </variable>
          <variable name="DT_S">
            <type>
              <REAL/>
            </type>
            <initialValue>
              <simpleValue value="0.02"/>
            </initialValue>
          </variable>
          <variable name="PHASE_IDLE">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="0"/>
            </initialValue>
          </variable>
          <variable name="PHASE_MOVE_TO_LIFT">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="1"/>
            </initialValue>
          </variable>
          <variable name="PHASE_LIFTING">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="2"/>
            </initialValue>
          </variable>
          <variable name="PHASE_MOVE_TO_SINK">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="3"/>
            </initialValue>
          </variable>
          <variable name="PHASE_SINKING">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="4"/>
            </initialValue>
          </variable>
          <variable name="Z_IDLE">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="0"/>
            </initialValue>
          </variable>
          <variable name="Z_DELAY_UP">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="1"/>
            </initialValue>
          </variable>
          <variable name="Z_UP_SLOW">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="2"/>
            </initialValue>
          </variable>
          <variable name="Z_UP_FAST">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="3"/>
            </initialValue>
          </variable>
          <variable name="Z_UP_SLOW_END">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="4"/>
            </initialValue>
          </variable>
          <variable name="Z_DRIP_UP">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="5"/>
            </initialValue>
          </variable>
          <variable name="Z_DELAY_DOWN">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="6"/>
            </initialValue>
          </variable>
          <variable name="Z_DOWN_FAST">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="7"/>
            </initialValue>
          </variable>
          <variable name="Z_DOWN_SLOW">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="8"/>
            </initialValue>
          </variable>
        </globalVars>
        <globalVars>
          <variable name="g_station_count">
            <type>
              <INT/>
            </type>
            <initialValue>
              <simpleValue value="0"/>
            </initialValue>
          </variable>
          <variable name="g_stations">
            <type>
              <array>
                <dimension lower="1" upper="21"/>
                <baseType>
                  <derived name="STATION_T"/>
                </baseType>
              </array>
            </type>
          </variable>
          <variable name="g_cfg">
            <type>
              <array>
                <dimension lower="1" upper="10"/>
                <baseType>
                  <derived name="TRANSPORTER_CFG_T"/>
                </baseType>
              </array>
