            <variable name="idx">
              <type>
                <INT/>
              </type>
            </variable>
            <variable name="tmp_st">
              <type>
                <derived name="STATION_T"/>
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[idx := FindStationIndexByNumber(station_number);
IF idx > 0 THEN
  tmp_st := g_stations[idx];
  GetStationType := tmp_st.station_type;
ELSE
  GetStationType := 0;
END_IF;]]></xhtml:p>
          </ST>
        </body>
      </pou>
